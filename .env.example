# --- Required ---

# Neon Postgres connection string (pooled or direct). Get from your Neon
# project dashboard → "Connection Details".
DATABASE_URL=

# Shared password for the team to log in at /login.
APP_PASSWORD=

# Random secret for signing session cookies. >= 16 chars.
# Generate: openssl rand -hex 32
AUTH_SECRET=

# Bearer token for the daily ranking cron. >= 8 chars; Render Cron sends it
# as Authorization: Bearer <token>. Generate: openssl rand -hex 32
CRON_TOKEN=
