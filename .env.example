# --- Required ---

# Neon Postgres connection string (pooled). Get from your Neon project
# dashboard → "Connection Details" → "Pooled connection".
DATABASE_URL=

# Random secret for signing session cookies. >= 16 chars.
# Generate: openssl rand -hex 32
AUTH_SECRET=

# Resend API key for sending magic-link emails.
RESEND_API_KEY=

# Sender address for magic-link emails. The domain must be verified in your
# Resend dashboard. Format: "Friendly Name <noreply@yourdomain.com>".
MAIL_FROM=

# Bearer token for the daily ranking cron. >= 8 chars; Render Cron sends it
# as Authorization: Bearer <token>. Generate: openssl rand -hex 32
CRON_TOKEN=

# --- Optional ---

# Public base URL of the deployment. On Render, the code falls back to
# RENDER_EXTERNAL_URL (auto-injected) when this is unset — only set explicitly
# if you've put a custom domain in front of the service.
# PUBLIC_BASE_URL=https://msr.yourdomain.com

# Comma-separated emails to seed into allowed_emails on every db:init run.
# Useful for bootstrapping admin access on a fresh deploy. Safe to leave set;
# already-existing addresses are ignored.
# INITIAL_ALLOWED_EMAILS=you@yourcompany.com,teammate@yourcompany.com
